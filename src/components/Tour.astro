  @media (prefers-reduced-motion: reduce) {
    [data-tour].is-ready .tour__step,
    [data-tour].is-ready .tour__card,
    .tour__dot {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector<HTMLElement>("[data-tour]");

  if (root) {
    const steps = Array.from(root.querySelectorAll<HTMLElement>("[data-tour-step]"));
    const cards = Array.from(root.querySelectorAll<HTMLElement>("[data-tour-card]"));
    const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-tour-panel]"));
    const dots = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-tour-dots] [data-dot]"),
    );

    const setActive = (i: number) => {
      steps.forEach((s, k) => s.classList.toggle("is-active", k === i));
      cards.forEach((c, k) => c.classList.toggle("is-active", k === i));
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
    };

    const mm = gsap.matchMedia();

    // --- Desktop: sticky scroll with cross-fading stage ---
    mm.add(
      "(min-width: 921px) and (prefers-reduced-motion: no-preference)",
      () => {
        root.classList.add("is-ready");
        setActive(0);

        // The step whose [top 60% → bottom 60%] band brackets the 60% line is
        // the active one. A single reference line keeps transitions clean.
        const triggers = steps.map((step, i) =>
          ScrollTrigger.create({
            trigger: step,
            start: "top 60%",
            end: "bottom 60%",
            onToggle: (self) => {
              if (self.isActive) setActive(i);
            },
          }),
        );

        ScrollTrigger.refresh();

        return () => {
          triggers.forEach((t) => t.kill());
          root.classList.remove("is-ready");
        };
      },
    );

    // --- Mobile: horizontal scroll-snap carousel ---
    mm.add("(max-width: 920px)", () => {
      setActive(0);

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const i = panels.indexOf(e.target as HTMLElement);
              if (i >= 0) setActive(i);
            }
          });
        },
        { root, threshold: 0.6 },
      );
      panels.forEach((p) => io.observe(p));

      const onDot = (e: Event) => {
        const i = Number((e.currentTarget as HTMLElement).dataset.dot);
        panels[i]?.scrollIntoView({
          behavior: "smooth",
          inline: "center",
          block: "nearest",
        });
      };
      dots.forEach((d) => d.addEventListener("click", onDot));

      return () => {
        io.disconnect();
        dots.forEach((d) => d.removeEventListener("click", onDot));
      };
    });
  }
</script>
