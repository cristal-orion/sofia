---
const links = [
  { href: "#canali", label: "Canali" },
  { href: "#oltre", label: "Cosa fa" },
  { href: "#integrazioni", label: "Integrazioni" },
  { href: "#settori", label: "Settori" },
  { href: "#faq", label: "FAQ" },
];
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a href="#top" class="nav__brand" aria-label="SofIA — home">
      <img
        src="/sofia-logo-full.webp"
        alt="SofIA"
        class="nav__logo"
        width="480"
        height="160"
        fetchpriority="high"
      />
    </a>

    <nav class="nav__links" aria-label="Sezioni">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav__cta">
      <a href="#prova" class="btn btn--primary" data-trial-open>
        <span class="dot-live" aria-hidden="true"></span>
        Prova SofIA
      </a>
    </div>

    <button class="nav__burger" aria-label="Apri menu" aria-expanded="false" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" data-mobile-menu hidden>
    {links.map((l) => <a href={l.href} data-mobile-link>{l.label}</a>)}
    <a href="#prova" class="btn btn--primary btn--lg" data-trial-open data-mobile-link>Prova SofIA</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 900;
    background: color-mix(in srgb, var(--cream) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .nav[data-scrolled] {
    border-bottom-color: var(--line);
    background: color-mix(in srgb, var(--cream) 92%, transparent);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 104px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
  }
  .nav__logo {
    height: 68px;
    width: auto;
    display: block;
  }
  .nav__links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .nav__links a {
    color: var(--ink-soft);
    transition: color 0.18s ease;
  }
  .nav__links a:hover {
    color: var(--coral-700);
  }
  .nav__cta {
    display: flex;
  }
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 12px;
    cursor: pointer;
  }
  .nav__burger span {
    width: 20px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .nav__burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav__burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem var(--gutter) 1.6rem;
    border-bottom: 1px solid var(--line);
    background: var(--cream);
  }
  .nav__mobile a:not(.btn) {
    padding: 0.8rem 0.4rem;
    font-weight: 600;
    border-bottom: 1px solid var(--line);
  }
  .nav__mobile .btn {
    margin-top: 0.6rem;
  }

  @media (max-width: 860px) {
    .nav__links,
    .nav__cta {
      display: none;
    }
    .nav__burger {
      display: flex;
      margin-left: auto;
    }
    .nav__mobile[data-open] {
      display: flex;
    }
  }
</style>
