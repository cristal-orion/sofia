---
/* SofIA orchestration diagram — warm isometric.
   Geometry is generated at build time so the iso projection is exact; text and
   icons live in an HTML overlay positioned over the SVG for crispness. The
   looping animation (channel → SofIA → agenda, language changing each cycle)
   is driven by GSAP in the client script below. Reduced-motion / no-JS show a
   complete static state (the initial markup is the rest state). */

const VB = { w: 520, h: 470 };
const pct = (v: number, total: number) => +((v / total) * 100).toFixed(2);

type Node = { x: number; y: number; a: number; h: number };
const N: Record<string, Node> = {
  hub: { x: 260, y: 214, a: 58, h: 40 },
  tel: { x: 96, y: 116, a: 40, h: 22 },
  chat: { x: 70, y: 220, a: 40, h: 22 },
  wa: { x: 112, y: 326, a: 40, h: 22 },
  agenda: { x: 432, y: 152, a: 46, h: 26 },
  report: { x: 448, y: 292, a: 40, h: 22 },
};

const faces = (n: Node) => {
  const b = n.a / 2;
  return {
    top: `M${n.x} ${n.y - b} L${n.x + n.a} ${n.y} L${n.x} ${n.y + b} L${n.x - n.a} ${n.y} Z`,
    left: `M${n.x - n.a} ${n.y} L${n.x} ${n.y + b} L${n.x} ${n.y + b + n.h} L${n.x - n.a} ${n.y + n.h} Z`,
    right: `M${n.x + n.a} ${n.y} L${n.x} ${n.y + b} L${n.x} ${n.y + b + n.h} L${n.x + n.a} ${n.y + n.h} Z`,
    anchor: { x: n.x, y: n.y - b },
    base: { x: n.x, y: n.y + b + n.h },
  };
};
const F = Object.fromEntries(Object.entries(N).map(([k, v]) => [k, faces(v)])) as Record<
  string,
  ReturnType<typeof faces>
>;

const conn = (a: { x: number; y: number }, b: { x: number; y: number }) => {
  const mx = (a.x + b.x) / 2;
  const my = (a.y + b.y) / 2 - 26;
  return `M${a.x} ${a.y} Q${mx} ${my} ${b.x} ${b.y}`;
};
const C = {
  tel: conn(F.tel.anchor, F.hub.anchor),
  chat: conn(F.chat.anchor, F.hub.anchor),
  wa: conn(F.wa.anchor, F.hub.anchor),
  agenda: conn(F.hub.anchor, F.agenda.anchor),
  report: conn(F.hub.anchor, F.report.anchor),
};

// back-to-front paint order
const order = ["tel", "agenda", "chat", "hub", "report", "wa"] as const;

const channels = [
  { key: "tel", label: "Telefono", flow: "in" },
  { key: "chat", label: "Chat", flow: "in" },
  { key: "wa", label: "WhatsApp", flow: "in" },
  { key: "agenda", label: "Agenda", flow: "out" },
  { key: "report", label: "Report", flow: "out" },
];

const ovl = (n: Node) => `left:${pct(n.x, VB.w)}%;top:${pct(n.y, VB.h)}%`;
---

<div class="orch" data-hero="6" data-orch aria-hidden="true">
  <svg
    class="orch__svg"
    viewBox={`0 0 ${VB.w} ${VB.h}`}
    fill="none"
    role="presentation"
  >
    <!-- ground shadows -->
    {order.map((k) => (
      <ellipse
        class="orch__shadow"
        cx={N[k].x}
        cy={F[k].base.y + 2}
        rx={N[k].a * 1.02}
        ry={N[k].a * 0.42}
      />
    ))}

    <!-- connectors: faint track + animated coral flow -->
    {Object.entries(C).map(([k, d]) => (
      <>
        <path class="orch__track" d={d} />
        <path id={`flow-${k}`} class={`orch__flow orch__flow--${k}`} d={d} />
        <path id={`conn-${k}`} d={d} style="visibility:hidden" />
      </>
    ))}

    <!-- iso blocks -->
    {order.map((k) => {
      const isHub = k === "hub";
      const c = isHub ? "hub" : "tile";
      return (
        <g class={`orch__block ${isHub ? "orch__block--hub" : ""}`} data-block={k}>
          <path class={`face face--left face--left-${c}`} d={F[k].left} />
          <path class={`face face--right face--right-${c}`} d={F[k].right} />
          <path class={`face face--top face--top-${c}`} d={F[k].top} />
        </g>
      );
    })}

    <!-- hub pulse rings (on top face) -->
    <ellipse id="hub-ring-1" class="orch__ring" cx={N.hub.x} cy={F.hub.anchor.y + N.hub.a / 2} rx={N.hub.a * 0.62} ry={N.hub.a * 0.31} />
    <ellipse id="hub-ring-2" class="orch__ring" cx={N.hub.x} cy={F.hub.anchor.y + N.hub.a / 2} rx={N.hub.a * 0.62} ry={N.hub.a * 0.31} />

    <!-- travelling pulses -->
    <circle id="pulse-in" class="orch__pulse" r="6" cx="0" cy="0" />
    <circle id="pulse-out1" class="orch__pulse orch__pulse--out" r="5" cx="0" cy="0" />
    <circle id="pulse-out2" class="orch__pulse orch__pulse--out" r="5" cx="0" cy="0" />
  </svg>

  <!-- HTML overlay: crisp icons + text -->
  <div class="orch__overlay">
    <!-- channel chips -->
    {channels.map((c) => (
      <div
        class={`orch__chip orch__chip--${c.key} ${c.key === "tel" ? "is-active" : ""}`}
        data-ch={c.key}
        style={ovl(N[c.key])}
      >
        <span class="orch__ico">
          {c.key === "tel" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          )}
          {c.key === "chat" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          )}
          {c.key === "wa" && (
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm5.8 14.01c-.25.69-1.45 1.32-2 1.36-.55.04-1.06.24-3.55-.74-3-1.18-4.92-4.25-5.07-4.45-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.05-2.49.28-.3.6-.37.8-.37.2 0 .4 0 .57.01.18.01.43-.07.67.51.25.6.85 2.07.92 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.17-.32.39-.45.52-.15.15-.31.31-.13.61.17.3.77 1.27 1.65 2.06 1.13 1.01 2.09 1.32 2.39 1.47.3.15.47.12.65-.07.17-.2.74-.87.94-1.16.2-.3.4-.25.67-.15.27.1 1.72.81 2.01.96.3.15.5.22.57.35.07.12.07.72-.18 1.41Z"/></svg>
          )}
          {c.key === "agenda" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          )}
          {c.key === "report" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 3-4 3 2 4-6"/></svg>
          )}
        </span>
        <span class="orch__label">{c.label}</span>
      </div>
    ))}

    <!-- hub mark -->
    <div class="orch__hub" style={`left:${pct(N.hub.x, VB.w)}%;top:${pct(N.hub.y - 4, VB.h)}%`}>
      <span class="orch__hub-dot"></span>
      <span class="orch__hub-name">SofIA</span>
    </div>

    <!-- hub language badge -->
    <div class="orch__lang" style={`left:${pct(N.hub.x, VB.w)}%;top:${pct(N.hub.y - 52, VB.h)}%`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18Z"/></svg>
      <span data-hub-lang>IT</span>
    </div>

    <!-- incoming greeting bubble (moves over active channel) -->
    <div class="orch__bubble" data-bubble style={`left:${pct(N.tel.x, VB.w)}%;top:${pct(N.tel.y - 30, VB.h)}%`}>
      <span data-bubble-flag>🇮🇹</span>
      <span data-bubble-msg>«Vorrei un appuntamento»</span>
    </div>

    <!-- agenda booked tag -->
    <div class="orch__agtag" data-agenda-tag style={`left:${pct(N.agenda.x, VB.w)}%;top:${pct(N.agenda.y + 40, VB.h)}%`}>
      <span>✓</span> Fissato
    </div>
  </div>
</div>

<style>
  .orch {
    position: relative;
    width: min(100%, 500px);
    aspect-ratio: 520 / 470;
    margin-inline: auto;
  }
  .orch__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .orch__shadow {
    fill: rgba(36, 31, 29, 0.13);
    filter: blur(7px);
  }

  /* connectors */
  .orch__track {
    stroke: var(--line);
    stroke-width: 2;
    fill: none;
  }
  .orch__flow {
    stroke: var(--coral);
    stroke-width: 2.4;
    fill: none;
    stroke-linecap: round;
    stroke-dasharray: 2 12;
    opacity: 0.55;
    animation: orch-flow 1.3s linear infinite;
  }
  /* outgoing lines flow the other way + greener */
  .orch__flow--agenda,
  .orch__flow--report {
    stroke: var(--green);
    animation-direction: reverse;
    animation-duration: 1.6s;
  }
  @keyframes orch-flow {
    to {
      stroke-dashoffset: -14;
    }
  }

  /* iso faces */
  .face {
    stroke: rgba(36, 31, 29, 0.08);
    stroke-width: 1;
    stroke-linejoin: round;
  }
  .face--top-tile {
    fill: var(--surface);
  }
  .face--left-tile {
    fill: #efe6d4;
  }
  .face--right-tile {
    fill: #e4d9c4;
  }
  .face--top-hub {
    fill: var(--coral);
  }
  .face--left-hub {
    fill: var(--coral-600);
  }
  .face--right-hub {
    fill: var(--coral-700);
  }

  /* hub rings */
  .orch__ring {
    fill: none;
    stroke: var(--coral);
    stroke-width: 2;
    opacity: 0;
    transform-box: fill-box;
  }

  /* travelling pulses */
  .orch__pulse {
    fill: var(--coral);
    opacity: 0;
    filter: drop-shadow(0 0 5px var(--glow-coral));
  }
  .orch__pulse--out {
    fill: var(--green);
    filter: drop-shadow(0 0 5px rgba(74, 93, 80, 0.55));
  }

  /* ---------- HTML overlay ---------- */
  .orch__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .orch__chip,
  .orch__hub,
  .orch__lang,
  .orch__bubble,
  .orch__agtag {
    position: absolute;
    transform: translate(-50%, -50%);
  }

  .orch__chip {
    display: grid;
    justify-items: center;
    gap: 0.3rem;
    transition:
      transform 0.4s var(--ease-out),
      filter 0.4s var(--ease-out);
  }
  .orch__ico {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }
  .orch__ico svg {
    width: 20px;
    height: 20px;
  }
  .orch__chip--tel .orch__ico {
    color: var(--coral);
  }
  .orch__chip--chat .orch__ico {
    color: var(--green);
  }
  .orch__chip--wa .orch__ico {
    color: var(--wa-green);
  }
  .orch__chip--agenda .orch__ico {
    color: var(--taupe-700);
  }
  .orch__chip--report .orch__ico {
    color: var(--green-700);
  }
  .orch__label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: var(--surface);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--line);
  }
  .orch__chip.is-active {
    transform: translate(-50%, -50%) scale(1.08);
  }
  .orch__chip.is-active .orch__ico {
    border-color: var(--coral);
    box-shadow:
      0 0 0 3px var(--coral-100),
      var(--shadow-coral);
  }

  /* hub */
  .orch__hub {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #fff;
  }
  .orch__hub-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.25);
  }
  .orch__hub-name {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }

  /* hub language badge */
  .orch__lang {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--green-900);
    color: var(--cream-soft);
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    box-shadow: var(--shadow-md);
  }
  .orch__lang svg {
    width: 14px;
    height: 14px;
    color: var(--coral);
  }

  /* greeting bubble */
  .orch__bubble {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    max-width: 200px;
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
    border-radius: 14px;
    border-bottom-left-radius: 5px;
    padding: 0.5rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    z-index: 3;
  }
  .orch__bubble [data-bubble-flag] {
    font-size: 1rem;
  }

  /* agenda booked tag */
  .orch__agtag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: linear-gradient(120deg, var(--coral-050), var(--surface));
    border: 1.5px solid var(--coral-100);
    color: var(--coral-700);
    font-weight: 700;
    font-size: 0.76rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
  }
  .orch__agtag span {
    display: grid;
    place-items: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--coral);
    color: #fff;
    font-size: 0.62rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .orch__flow {
      animation: none;
    }
  }

  @media (max-width: 920px) {
    .orch {
      width: min(100%, 440px);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { MotionPathPlugin } from "gsap/MotionPathPlugin";

  const root = document.querySelector<HTMLElement>("[data-orch]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (root && !reduce) {
    gsap.registerPlugin(MotionPathPlugin);

    const q = <T extends Element>(s: string) => root.querySelector<T>(s)!;
    const bubble = q<HTMLElement>("[data-bubble]");
    const bubbleFlag = q<HTMLElement>("[data-bubble-flag]");
    const bubbleMsg = q<HTMLElement>("[data-bubble-msg]");
    const hubLang = q<HTMLElement>("[data-hub-lang]");
    const agTag = q<HTMLElement>("[data-agenda-tag]");

    type Cycle = { ch: string; lang: string; flag: string; msg: string };
    const cycles: Cycle[] = [
      { ch: "tel", lang: "IT", flag: "🇮🇹", msg: "«Vorrei un appuntamento»" },
      { ch: "wa", lang: "EN", flag: "🇬🇧", msg: "«Can I book a visit?»" },
      { ch: "chat", lang: "ES", flag: "🇪🇸", msg: "«¿Tienen hueco mañana?»" },
      { ch: "tel", lang: "FR", flag: "🇫🇷", msg: "«Je voudrais un rendez-vous»" },
      { ch: "wa", lang: "DE", flag: "🇩🇪", msg: "«Ich hätte gern einen Termin»" },
      { ch: "chat", lang: "AR", flag: "🇸🇦", msg: "«أريد حجز موعد»" },
    ];

    // start hidden — initial markup was the rest state for no-JS / reduced
    gsap.set([bubble, agTag], { opacity: 0 });
    root.querySelectorAll(".orch__chip").forEach((c) => c.classList.remove("is-active"));

    const placeOver = (ch: string) => {
      const chip = root.querySelector<HTMLElement>(`[data-ch="${ch}"]`)!;
      const r = root.getBoundingClientRect();
      const c = chip.getBoundingClientRect();
      bubble.style.left = `${((c.left + c.width / 2 - r.left) / r.width) * 100}%`;
      bubble.style.top = `${((c.top - r.top) / r.height) * 100 - 7}%`;
    };

    const firePulse = (id: string, connKey: string, out: boolean, dur: number) => {
      const p = q<SVGCircleElement>(id);
      const path = q<SVGPathElement>(`#conn-${connKey}`);
      gsap.set(p, { opacity: 1 });
      gsap.to(p, {
        duration: dur,
        ease: "power1.inOut",
        motionPath: { path, align: path, alignOrigin: [0.5, 0.5] },
        onComplete: () => gsap.set(p, { opacity: 0 }),
      });
    };

    const pulseRings = () => {
      gsap.fromTo(
        ["#hub-ring-1", "#hub-ring-2"],
        { scale: 0.35, opacity: 0.55, transformOrigin: "center" },
        {
          scale: 1.35,
          opacity: 0,
          duration: 1.1,
          ease: "power2.out",
          stagger: 0.22,
          svgOrigin: `${260} ${214 - 58 / 2 + 58 / 2}`,
        },
      );
    };

    let i = 0;
    const runCycle = () => {
      const c = cycles[i % cycles.length];
      i++;
      const chip = root.querySelector<HTMLElement>(`[data-ch="${c.ch}"]`)!;

      const tl = gsap.timeline({
        onComplete: runCycle,
        defaults: { ease: "power2.out" },
      });

      tl.call(() => {
        bubbleFlag.textContent = c.flag;
        bubbleMsg.textContent = c.msg;
        placeOver(c.ch);
        chip.classList.add("is-active");
      });

      // 1 · message arrives at the channel
      tl.fromTo(
        bubble,
        { opacity: 0, scale: 0.7, y: 6 },
        { opacity: 1, scale: 1, y: 0, duration: 0.5 },
        "+=0.1",
      );

      // 2 · pulse travels channel → SofIA
      tl.call(() => firePulse("#pulse-in", c.ch, false, 0.85), [], "+=0.35");
      tl.call(() => {
        pulseRings();
        hubLang.textContent = c.lang;
      }, [], "+=0.7");

      // 3 · SofIA acts → agenda + report
      tl.call(() => {
        firePulse("#pulse-out1", "agenda", true, 0.8);
        firePulse("#pulse-out2", "report", true, 0.9);
      }, [], "+=0.15");
      tl.fromTo(
        agTag,
        { opacity: 0, scale: 0.8, y: 5 },
        { opacity: 1, scale: 1, y: 0, duration: 0.4 },
        "+=0.55",
      );

      // 4 · settle, then reset for next language
      tl.to(bubble, { opacity: 0, scale: 0.85, duration: 0.4 }, "+=0.9");
      tl.to(agTag, { opacity: 0, duration: 0.4 }, "<");
      tl.call(() => chip.classList.remove("is-active"));
      tl.to({}, { duration: 0.35 });
    };

    // gentle perpetual breathing on the hub mark
    gsap.to(".orch__hub-dot", {
      scale: 1.25,
      duration: 1.4,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      transformOrigin: "center",
    });

    runCycle();
  }
</script>
